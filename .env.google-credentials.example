# ============================================
# GOOGLE OAUTH CREDENTIALS SETUP TEMPLATE
# ============================================
# Setelah mendapatkan credentials dari Google Cloud Console,
# copy values di bawah ke file .env Anda

# Google OAuth Client ID (dari Google Cloud Console)
GOOGLE_CLIENT_ID=your_client_id_here

# Google OAuth Client Secret (dari Google Cloud Console)
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Google OAuth Redirect URL
# Untuk development: http://localhost:8000/auth/google/callback
# Untuk production: https://yourdomain.com/auth/google/callback
GOOGLE_REDIRECT_URL=http://localhost:8000/auth/google/callback

# ============================================
# Contoh nilai yang sudah diisi (DEMO ONLY):
# ============================================
# GOOGLE_CLIENT_ID=123456789-abcdefghijklmn.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-1a2b3c4d5e6f7g8h9i0j
# GOOGLE_REDIRECT_URL=http://localhost:8000/auth/google/callback

# ============================================
# Setup Guide:
# ============================================
# 1. Buka: https://console.cloud.google.com
# 2. Create project atau pilih existing
# 3. Enable Google+ API
# 4. Buat OAuth 2.0 Client ID (Web Application)
# 5. Set Authorized Redirect URIs:
#    - http://localhost:8000/auth/google/callback (development)
#    - https://yourdomain.com/auth/google/callback (production)
# 6. Copy Client ID dan Secret ke .env
# 7. Jalankan: php artisan config:clear
# 8. Selesai!
